---
import PathIcon from '@/icons/pathIcon.astro'

const features = [
  {
    title: "Smart distribution",
    desc: "Routes traffic intelligently — cheaper models for simple tasks, premium only when needed.",
    icon: "M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"
  },
  {
    title: "Automation with control",
    desc: "Automation is the default, but you're never locked in. Force providers or override decisions when your system demands it.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
  },
  {
    title: "No vendor lock-in",
    desc: "Works across multiple AI platforms and custom endpoints. Your system stays flexible as the AI ecosystem evolves.",
    icon: "M21 12V7H5a2 2 0 0 1 0-4h14v4"
  },
  {
    title: "Single endpoint",
    desc: "Integrate once. One API, one contract. Switch strategies on the fly without redeploying your app.",
    icon: "M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16M4 18h.01"
  }
]
---
<section class="max-w-6xl mx-auto px-6 py-24 relative z-10 animate-fade-up opacity-0 delay-400">

  <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/10 pb-10">
    <div>
      <p class="font-mono text-purple-300 text-xs tracking-widest uppercase mb-4 flex items-center gap-3">
        <span class="w-4 h-px bg-purple-500/50"></span>
        Architecture
      </p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-white tracking-tight">
        A cost-optimization layer<br/>for AI systems.
      </h2>
    </div>
    <p class="text-gray-500 font-light max-w-xs md:text-right text-sm leading-relaxed">
      Your app sends requests to Nexus. We handle the routing, the cost, and the fallback logic.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {features.map((feature, idx) => (
      <div class="group relative p-8 border border-white/5 bg-white/2 hover:bg-white/4 hover:border-white/10 rounded-sm transition-all duration-300 overflow-hidden">
        {idx === 0 && <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-500/8 blur-[50px] group-hover:bg-purple-500/15 transition-all"></div>}

        <div class="w-9 h-9 border border-white/10 bg-black/40 flex items-center justify-center text-gray-500 mb-6 group-hover:text-white group-hover:border-white/20 transition-colors rounded-sm">
          <PathIcon d={feature.icon} size={16} />
        </div>

        <!-- Título sin guion bajo — consistencia -->
        <h3 class="font-medium text-white text-base mb-3 tracking-tight">{feature.title}</h3>
        <p class="text-gray-500 font-light text-sm leading-relaxed">{feature.desc}</p>
      </div>
    ))}
  </div>
</section>

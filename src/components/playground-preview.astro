---
import BoltIcon from '@/icons/bolt.astro'
import BoxIcon from '@/icons/box.astro'
import SendIcon from '@/icons/send.astro'
import IntegrationIcon from '@/icons/integration.astro'
---

<section
  class="animate-fade-up relative z-10 mx-auto mt-20 mb-32 w-full max-w-6xl px-6 opacity-0 delay-300 md:mt-32"
>
  <!-- Header of section -->
  <div class="mb-12 flex flex-col items-center text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-rose-500/30 bg-rose-500/5 px-3 py-1.5 font-mono text-xs tracking-widest text-rose-300 uppercase backdrop-blur-sm"
    >
      <BoltIcon class="animate-pulse text-rose-400" size={16} />
      Live Telemetry
    </div>

    <h2
      class="font-display mb-6 text-4xl font-bold tracking-tight text-white md:text-5xl"
    >
      Automation with control
    </h2>
    <p class="max-w-2xl text-lg font-light text-gray-400">
      Nexus can choose models for you — but you’re never locked in. Override
      decisions when you want. Automation is the default, control is always
      available.
    </p>
  </div>

  <!-- Terminal/Dashboard UI -->
  <div
    class="group relative overflow-hidden border border-white/10 bg-[#0a0718] shadow-[0_0_80px_-20px_rgba(139,92,246,0.15)] backdrop-blur-2xl"
  >
    <!-- Internal ambient glow -->
    <div
      class="pointer-events-none absolute -top-40 -right-40 h-96 w-96 rounded-full bg-purple-600/10 blur-[80px] transition-transform duration-1000 group-hover:translate-x-10 group-hover:translate-y-10"
    >
    </div>

    <!-- Top Bar -->
    <div
      class="relative z-10 flex items-center justify-between border-b border-white/10 bg-white/2 px-4 py-3"
    >
      <div class="flex gap-2">
        <!-- Brutalist Window Controls -->
        <div class="h-3 w-3 border border-white/20 bg-white/10"></div>
        <div class="h-3 w-3 border border-white/20 bg-white/10"></div>
        <div
          class="h-3 w-3 border border-purple-500/50 bg-purple-500/50 shadow-[0_0_10px_rgba(168,85,247,0.5)]"
        >
        </div>
      </div>
      <div
        class="absolute left-1/2 -translate-x-1/2 font-mono text-xs text-gray-500"
      >
        ~ /nexus /<span class="text-white">playground.ts</span>
      </div>
      <div
        class="hidden border border-purple-500/20 bg-purple-500/10 px-2.5 py-1 font-mono text-[10px] tracking-widest text-purple-300 uppercase md:block"
      >
        Status: Connected
      </div>
    </div>

    <!-- Main Grid -->
    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-3">
      <!-- Left Pane: Chat/Interaction -->
      <div
        class="col-span-2 flex min-h-125 flex-col justify-between border-r border-white/10 p-6 md:p-8"
      >
        <!-- Messages -->
        <div class="space-y-8">
          <!-- User Block -->
          <div class="flex items-start justify-end gap-4">
            <div
              class="max-w-[80%] border border-white/10 bg-white/5 p-4 font-sans text-sm text-gray-200"
            >
              Summarize this support ticket and suggest a priority level.
            </div>
            <div
              class="flex h-8 w-8 shrink-0 items-center justify-center border border-white/20 bg-white/10 font-mono text-xs text-white/50"
            >
              U
            </div>
          </div>

          <!-- AI Block -->
          <div class="flex items-start justify-start gap-4">
            <div
              class="flex h-8 w-8 shrink-0 items-center justify-center border border-purple-500/30 bg-purple-500/10 text-purple-400"
            >
              <BoxIcon size={16} />
            </div>
            <div
              class="border-l-2 border-purple-500/50 bg-transparent py-1 pl-5 font-sans text-sm leading-relaxed font-light text-gray-300"
            >
              <span class="font-medium text-white">Summary:</span> User reports billing
              discrepancy after plan upgrade.<br /><br />
              <span class="font-medium text-white">Priority:</span>
              <span class="text-rose-300">High</span> — immediate financial impact.
            </div>
          </div>
        </div>

        <!-- Input Area -->
        <div class="mt-12 flex gap-3">
          <div class="relative flex-1">
            <div
              class="absolute top-1/2 left-4 -translate-y-1/2 font-mono text-xs text-purple-500"
            >
              {'>'}
            </div>
            <input
              type="text"
              placeholder="Send a request to the routing layer..."
              class="w-full border border-white/10 bg-[#05030a] py-3.5 pr-4 pl-10 font-mono text-sm text-white placeholder-gray-600 transition-colors focus:border-purple-500/50 focus:outline-none"
              disabled
            />
          </div>
          <button
            class="group flex items-center justify-center gap-2 border border-white bg-white px-6 font-mono text-sm tracking-widest text-[#0a0718] uppercase transition-colors hover:bg-purple-200"
          >
            <span class="hidden sm:inline">Execute</span>
            <SendIcon
              size={16}
              class="transition-transform group-hover:translate-x-1"
            />
          </button>
        </div>
      </div>

      <!-- Right Pane: Configuration -->
      <div
        class="col-span-1 border-t border-white/10 bg-white/1 p-6 md:p-8 lg:border-t-0"
      >
        <h3
          class="font-display mb-8 border-b border-white/10 pb-4 text-lg font-semibold text-white"
        >
          Routing_
        </h3>

        <!-- Config: Provider -->
        <div class="mb-6">
          <label
            class="mb-2 flex justify-between font-mono text-[10px] tracking-widest text-gray-500 uppercase"
          >
            <span>Provider</span>
            <span class="text-rose-400/80">COST: $0.0002</span>
          </label>
          <div
            class="flex cursor-pointer items-center justify-between border border-white/10 bg-[#05030a] p-3 font-sans text-sm text-gray-300 transition-colors hover:border-white/30"
          >
            Google Gemini
          </div>
        </div>

        <!-- Config: Model -->
        <div class="mb-8">
          <label
            class="mb-2 block font-mono text-[10px] tracking-widest text-gray-500 uppercase"
            >Model</label
          >
          <div
            class="flex cursor-pointer items-center justify-between border border-purple-500/30 bg-purple-500/5 p-3 font-mono text-sm text-purple-200 shadow-[inset_0_0_20px_rgba(168,85,247,0.05)]"
          >
            gemini-3.1-flash
            <div class="h-1.5 w-1.5 animate-pulse rounded-full bg-purple-400">
            </div>
          </div>
        </div>

        <!-- Config: Temperature -->
        <div class="mb-10">
          <div
            class="mb-3 flex justify-between font-mono text-[10px] tracking-widest text-gray-500 uppercase"
          >
            <span>Deterministic</span>
            <span>Creative</span>
          </div>
          <div class="relative h-px w-full bg-white/20">
            <!-- Active Track -->
            <div
              class="absolute top-0 left-0 h-full w-[70%] bg-purple-500 shadow-[0_0_10px_rgba(168,85,247,0.5)]"
            >
            </div>
            <!-- Thumb -->
            <div
              class="absolute top-1/2 left-[70%] h-5 w-3 -translate-x-1/2 -translate-y-1/2 cursor-ew-resize border border-purple-300 bg-white transition-transform hover:scale-110"
            >
            </div>
          </div>
          <div class="mt-3 text-right font-mono text-xs text-purple-300">
            0.7
          </div>
        </div>

        <!-- CLI Snippet -->
        <div>
          <label
            class="mb-2 flex items-center justify-between font-mono text-[10px] tracking-widest text-gray-500 uppercase"
          >
            <span>Integration</span>
            <button class="transition-colors hover:text-white">
              <IntegrationIcon size={14} />
            </button>
          </label>
          <div
            class="overflow-x-auto border border-white/5 bg-[#05030a] p-4 font-mono text-[11px] leading-relaxed text-gray-300 lg:text-xs"
          >
            <span class="text-purple-400">const</span>
            <span class="text-blue-300">res</span> = <span
              class="text-purple-400">await</span
            > nexus.<span class="text-blue-300">create</span>(&#123; <br />
            &nbsp;&nbsp;&nbsp;<span class="text-gray-500"
              >// model auto-selected for cost</span
            ><br />
            &nbsp;&nbsp;&nbsp;messages: [...] <br />
            &#125;);
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

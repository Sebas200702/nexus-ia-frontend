---
interface Props {
  class?: string
  size?: number
}
const { class: className = '', size } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="1.75"
  class={className}
  ><path stroke="none" d="M0 0h24v24H0z"></path><path
    d="M5 12h14M15 16l4-4M15 8l4 4"></path></svg
>

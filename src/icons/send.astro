---
interface Props {
  class?: string
  size?: number
}
const { class: className = '', size = 16 } = Astro.props as Props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="1.75"
  class={className}
  ><path stroke="none" d="M0 0h24v24H0z"></path><path
    d="M10 14 21 3M21 3l-6.5 18a.55.55 0 0 1-1 0L10 14l-7-3.5a.55.55 0 0 1 0-1z"
  ></path></svg
>
